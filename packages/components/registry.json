{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "ez-ui",
  "homepage": "https://github.com/ezDecode/ez.ui",
  "items": [
    {
      "name": "stamp-collection",
      "type": "registry:block",
      "title": "Stamp Collection",
      "description": "Interactive stamp deck with hover physics and spring-based motion",
      "dependencies": ["motion", "next", "react"],
      "files": [
        {
          "type": "registry:component",
          "path": "registry/new-york/stamp-collection.tsx",
          "target": "components/ui/stamp-collection.tsx"
        }
      ]
    },
    {
      "name": "preview",
      "type": "registry:block",
      "title": "Preview",
      "description": "Component preview wrapper with background options",
      "dependencies": ["react"],
      "files": [
        {
          "type": "registry:component",
          "path": "registry/new-york/preview.tsx",
          "target": "components/ui/preview.tsx"
        }
      ]
    },
    {
      "name": "animate-in",
      "type": "registry:block",
      "title": "AnimateIn",
      "description": "Fade-in animation wrapper component with spring easing",
      "dependencies": ["motion", "react"],
      "files": [
        {
          "type": "registry:component",
          "path": "registry/new-york/animate-in.tsx",
          "target": "components/ui/animate-in.tsx"
        }
      ]
    }
  ]
}
