{
  "name": "@ez/ui",
  "version": "1.0.0",
  "type": "module",
  "description": "CLI to add ez.ui components to your project",
  "bin": {
    "ez-ui": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=bin/cli.js --format=esm --banner:js='#!/usr/bin/env node'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cosmiconfig": "^8.3.6",
    "prompts": "^2.4.2",
    "fast-glob": "^3.3.2",
    "zod": "^3.23.8",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "undici": "^6.13.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "esbuild": "^0.20.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
