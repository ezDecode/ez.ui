{
  "name": "ez.ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run registry:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "registry:generate": "node scripts/generate-registry.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.24.10",
    "geist": "^1.7.0",
    "gsap": "^3.12.7",
    "lucide-react": "^0.552.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^3.5.0",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "tailwindcss": "4.2.1",
    "typescript": "^5"
  }
}
